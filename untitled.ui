  <property name="styleSheet">
   <string notr="true">/* ===== GLOBAL ===== */

QMainWindow, QWidget {
    background-color: #eef5f3;
    font-family: &quot;SF Pro Display&quot;, &quot;Segoe UI&quot;, Arial;
    font-size: 14px;
    color: #2c3e3a;
}


/* ===== TITLE FRAME ===== */

#title_frame {
    background-color: #e4f0ec;
    border-radius: 10px;
}

#title_frame QLabel {
    color: #4aa485;
    font-size: 26px;
    font-weight: 600;
}


/* ===== SECTION HEADER ===== */

QLabel {
    color: #4aa485;
    font-weight: 600;
}


/* ===== INPUTS ===== */

QLineEdit,
QComboBox,
QSpinBox {
    background: white;
    border: 2px solid #d7e7e2;
    border-radius: 8px;
    padding: 6px 8px;
}

QLineEdit:focus,
QComboBox:focus,
QSpinBox:focus {
    border: 2px solid #5FB79B;
}


/* ===== COMBOBOX ===== */

QComboBox::drop-down {
    border: none;
}

QComboBox::down-arrow {
    image: none;
}


/* ===== TOOLBOX ===== */

QToolBox::tab {
    background: #e4f0ec;
    border-radius: 8px;
    padding: 6px;
    font-weight: 600;
}

QToolBox::tab:selected {
    background: #5FB79B;
    color: white;
}


/* ===== QUESTION BOX ===== */

QFrame {
    background: white;
    border-radius: 12px;
    border: 1px solid #d9e8e3;
}


/* ===== QUESTION TITLE BAR ===== */

QLabel#questionTitle {
    background: #5FB79B;
    color: white;
    padding: 8px;
    border-radius: 8px;
}


/* ===== RADIO BUTTON ===== */

QRadioButton {
    spacing: 8px;
    font-size: 14px;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
}

QRadioButton::indicator:unchecked {
    border: 2px solid #9dcfc0;
    border-radius: 8px;
    background: white;
}

QRadioButton::indicator:checked {
    border: 2px solid #5FB79B;
    border-radius: 8px;
    background: #5FB79B;
}


/* ===== MAIN BUTTON ===== */

QPushButton {
    background-color: #5FB79B;
    border-radius: 20px;
    padding: 10px 20px;
    color: white;
    font-size: 15px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #4aa485;
}

QPushButton:pressed {
    background-color: #3c8e74;
}


/* ===== LARGE API BUTTON ===== */

QPushButton#fetchButton {
    font-size: 18px;
    padding: 14px;
}


/* ===== SECONDARY BUTTON ===== */

QPushButton#retryButton {
    background-color: #9fd7c6;
}

QPushButton#retryButton:hover {
    background-color: #8acbb7;
}


/* ===== PROGRESS BADGE ===== */

QLabel#progressLabel {
    background: #5FB79B;
    color: white;
    padding: 6px 12px;
    border-radius: 10px;
}


/* ===== TEXT QUESTION AREA ===== */

QTextEdit {
    background: #f7fbf9;
    border-radius: 10px;
    border: 1px solid #d8ebe5;
    padding: 10px;
}


</string>
